# Variáveis de ambiente para microserviços

# PostgreSQL
POSTGRES_DB=estoque_db
POSTGRES_USER=estoque_user
POSTGRES_PASSWORD=estoque_pass

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Configuration
JWT_SECRET_KEY=sua-chave-secreta-muito-segura-para-producao-mude-isso
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Services URLs (internal)
PRODUTO_SERVICE_URL=http://produto-service:8001
PEDIDO_SERVICE_URL=http://pedido-service:8002
CALCULO_SERVICE_URL=http://calculo-service:8003
AUTH_SERVICE_URL=http://auth-service:8004
