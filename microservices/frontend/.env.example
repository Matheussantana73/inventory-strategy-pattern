# ============================================
# Configuração de URLs dos Microserviços
# ============================================

# Para produção no Render.com (ajuste com suas URLs reais após deploy)
VITE_AUTH_SERVICE_URL=https://auth-service.onrender.com
VITE_PRODUTO_SERVICE_URL=https://produto-service.onrender.com
VITE_PEDIDO_SERVICE_URL=https://pedido-service.onrender.com
VITE_CALCULO_SERVICE_URL=https://calculo-service.onrender.com

# Para desenvolvimento local com Docker (comentar as URLs acima e descomentar abaixo)
# VITE_AUTH_SERVICE_URL=http://localhost/api/v1/auth
# VITE_PRODUTO_SERVICE_URL=http://localhost/api/v1/produtos
# VITE_PEDIDO_SERVICE_URL=http://localhost/api/v1/pedidos
# VITE_CALCULO_SERVICE_URL=http://localhost/api/v1/calculos

# Configurações do app
VITE_APP_NAME=Sistema de Estoque
VITE_APP_VERSION=1.0.0
