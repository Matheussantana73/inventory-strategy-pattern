# Configuração para produção (Render.com)
# Estas variáveis serão definidas no painel do Render

# URLs dos microserviços (serão preenchidas automaticamente pelo Render)
VITE_AUTH_SERVICE_URL=
VITE_PRODUTO_SERVICE_URL=
VITE_PEDIDO_SERVICE_URL=
VITE_CALCULO_SERVICE_URL=

# Não usar API Gateway em produção (cada serviço tem sua URL)
VITE_USE_API_GATEWAY=false

# Informações do app
VITE_APP_NAME=Sistema de Estoque
VITE_APP_VERSION=1.0.0
